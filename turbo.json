{
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "start": {
      "outputs": [],
      "persistent": true
    },
    "start:addon": {
      "dependsOn": ["build"],
      "outputs": ["ember-stereo/dist/**"],
      "persistent": true
    },
    "start:test": {
      "outputs": ["test-app/dist"],
      "persistent": true
    },
    "start:docs": {
      "dependsOn": ["start:addon"],
      "outputs": ["docs/**"],
      "persistent": true
    },
    "lint": {
      "outputs": []
    }
  }
}
