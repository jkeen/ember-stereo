+    }
+    super._onAudioPaused();
+  }
+
+  _onAudioEnded() {
+    if (this._isGenuineEnd()) {
+      super._onAudioEnded();
+    }
+  }
+
+  _isGenuineEnd() {
+    let element = this.audioElement;
+    if (!element || !Number.isFinite(element.duration)) {
