+  static key = 'NativeAudioCasting';
+  static toString() {
+    return 'NativeAudioCasting';
+  }
+
+  // Only ever placed in the strategy list by the service while casting, so it
+  // never needs to gate on mime type — the device fetches whatever URL it's
