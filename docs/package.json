    "qunit-dom": "^2.0.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-prettier": "^4.0.2",
    "tailwindcss": "^2.2.19",
    "tailwindcss-theming": "3.0.0-beta.3",
    "tracked-built-ins": "^3.3.0",
    "webpack": "^5.89.0"
  },
  "engines": {
    "node": ">= 20.19"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "paths": [
      "../ember-stereo/"
    ]
  },
  "dependenciesMeta": {
    "ember-stereo": {
      "injected": true
    }
  },
  "volta": {
    "extends": "../package.json"
  }
