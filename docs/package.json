{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "description": "Ember stereo docs",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "pnpm dlx concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "pnpm dlx concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "pnpm dlx concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "concurrently 'ember serve -p 4101' --names 'docs serve'",
    "test": "pnpm dlx concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\"",
    "test:ember": "ember test"
  },
  "dependencies": {
    "@ember/string": "^4.0.1",
    "debug": "4.3.2",
    "ember-auto-import": "^2.6.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/eslint-parser": "^7.22.15",
    "@babel/plugin-proposal-decorators": "^7.23.2",
    "@ctrl/tinycolor": "^3.6.0",
    "@ember/optional-features": "^2.0.0",
    "@ember/string": "^3.1.1",
    "@ember/test-helpers": "^3.2.0",
    "@fullhuman/postcss-purgecss": "^4.1.3",
    "@glimmer/component": "^1.1.2",
    "ember-inflector": "^4.0.3",
    "@glimmer/tracking": "^1.1.2",
    "@tailwindcss/forms": "^0.3.4",
    "autoprefixer": "^10.4.14",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^8.2.2",
    "ember-cli": "~5.4.2",
    "ember-cli-addon-docs": "^9.0.0",
    "ember-cli-addon-docs-yuidoc": "^1.0.0",
    "ember-cli-app-version": "^6.0.1",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.2",
    "ember-cli-deploy": "^1.0.2",
    "ember-cli-deploy-build": "^2.0.0",
    "ember-cli-deploy-git": "^1.3.4",
