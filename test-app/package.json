{
  "name": "test-app",
  "version": "0.0.0",
  "private": true,
  "description": "ember stereo tests",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "pnpm dlx concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "pnpm dlx concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint ./**/*.hbs",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "concurrently 'ember test --server' --names 'tests serve'",
    "test": "pnpm dlx concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\"",
    "test:ember": "ember test",
    "test:ember-try:one": "ember try:one"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@ember/optional-features": "^2.2.0",
    "@ember/string": "^3.1.1",
    "@ember/test-helpers": "^3.3.1",
    "@embroider/test-setup": "^1.8.3",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^8.2.2",
    "date-fns": "^3.6.0",
    "debug": "4.3.2",
    "ember-auto-import": "^2.11.2",
    "ember-cli": "~5.4.2",
    "ember-cli-app-version": "^6.0.1",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-custom-assertions": "^0.3.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-concurrency": "^4.0.6",
    "ember-data": "~5.3.13",
    "ember-fetch": "^8.1.2",
    "ember-load-initializers": "^2.1.2",
    "ember-modifier": "^4.2.2",
    "ember-inflector": "^4.0.3",
    "ember-page-title": "^8.2.4",
    "ember-qunit": "^8.1.1",
    "ember-resolver": "^11.0.1",
    "ember-sinon": "^5.0.0",
    "ember-sinon-qunit": "7.1.4",
    "ember-source": "~5.4.1",
    "ember-source-channel-url": "^3.0.0",
    "ember-stereo": "workspace:^",
    "ember-template-lint": "^5.13.0",
    "ember-try": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ember": "^11.12.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-qunit": "^8.2.5",
    "loader.js": "^4.7.0",
    "prettier": "^3.6.2",
    "qunit": "^2.24.2",
    "qunit-dom": "^2.0.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-prettier": "^4.1.0",
    "tracked-built-ins": "^3.4.0",
    "webpack": "^5.103.0"
  },
  "dependenciesMeta": {
    "ember-stereo": {
      "injected": true
    }
  },
  "engines": {
    "node": ">= 20.19"
  },
  "ember-addon": {
    "paths": [
      "../ember-stereo/"
    ]
  },
  "ember": {
    "edition": "octane"
  },
  "volta": {
    "extends": "../package.json"
  }
}
