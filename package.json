{
  "private": true,
  "name": "ember-stereo",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkeen/ember-stereo.git"
  },
  "license": "MIT",
  "author": "Jeff Keen",
  "scripts": {
    "build": "pnpm --filter ember-stereo run build",
    "lint": "pnpm --filter '*' run lint",
    "lint:fix": "pnpm --filter '*' run lint:fix",
    "prepare": "pnpm build",
    "start": "turbo run start",
    "start:addon": "turbo run start --filter=ember-stereo",
    "start:test": "turbo run start --filter=test-app",
    "start:docs": "turbo run start --filter=docs",
    "test": "pnpm --filter test-app run test",
    "test:ember-compatibility": "ember try:each",
    "semantic-release": "pnpm --filter ember-stereo run semantic-release",
    "format": "prettier --write \"**/*.{js,hbs,ts,tsx,md}\""
  },
  "packageManager": "pnpm@10.17.0",
  "volta": {
    "node": "20.19.0",
    "yarn": "1.22.17",
    "npm": "7.22.0",
    "pnpm": "10.17.1"
  },
  "dependencies": {
    "@ember/string": "^4.0.1"
  },
  "devDependencies": {
    "@glimmer/component": "^1.1.2",
    "@tailwindcss/forms": "^0.3.4",
    "autoprefixer": "^10.4.23",
    "babel-eslint": "^10.1.0",
    "broccoli-asset-rev": "3.0.0",
    "ember-inflector": "^4.0.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-ember": "^10.6.1",
    "eslint-plugin-ember-concurrency": "^0.3.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-qunit": "^6.2.0",
    "loader.js": "^4.7.0",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^8.0.2",
    "postcss-import": "^14.1.0",
    "postcss-include-media": "^1.1.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^2.8.8",
    "qunit": "^2.24.3",
    "qunit-dom": "^1.6.0",
    "turbo": "^2.7.1",
    "webpack": "^5.104.1"
  },
  "pnpm": {
    "overrides": {
      "ember-concurrency": "^4.0.6"
    }
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "homepage": "https://ember-stereo.com"
}
